# =============================================================================
# mcp-brasil — Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e preencha os valores necessários:
#   cp .env.example .env

# --- Transparência (obrigatória para a feature transparencia) ---
# Cadastre-se gratuitamente em:
# https://portaldatransparencia.gov.br/api-de-dados/cadastrar-email
TRANSPARENCIA_API_KEY=

# --- HTTP Client (opcional — valores padrão já funcionam) ---
# MCP_BRASIL_HTTP_TIMEOUT=30.0
# MCP_BRASIL_HTTP_MAX_RETRIES=3
# MCP_BRASIL_HTTP_BACKOFF_BASE=1.0
# MCP_BRASIL_USER_AGENT=mcp-brasil/0.1.0
